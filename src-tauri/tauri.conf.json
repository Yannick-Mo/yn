{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "YN",
  "version": "0.1.0",
  "identifier": "com.yn.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "YN · 一念",
        "width": 800,
        "height": 600,
        "minWidth": 640,
        "minHeight": 420,
        "center": true,
        "decorations": true,
        "visible": true
      },
      {
        "label": "floating",
        "title": "YN Float",
        "width": 360,
        "height": 200,
        "center": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": true,
        "transparent": true,
        "shadow": false,
        "focus": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "YN Team",
    "copyright": "MIT",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "",
      "endpoints": [
        "https://github.com/YOUR_USERNAME/YN/releases/latest/download/{{target}}-{{arch}}-{{current_version}}.{{format}}-sig"
      ]
    }
  }
}
